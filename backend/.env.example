# ── Database ──────────────────────────────────────────
DB_HOST=db_host
DB_PORT=3306
DB_USER=db_user
DB_PASSWORD=db_pwd
DB_NAME=db_name

# ── WhatsApp Unofficial API ───────────────────────────
WA_PRODUCT_ID=your_product_id_here
WA_TOKEN=your_token_here
WA_PHONE_ID=your_phone_id_here
WA_BASE_URL=https://gate.whapi.cloud

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Drive ─────────────────────────────────────
# Path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=./google_service_account.json
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── App ───────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

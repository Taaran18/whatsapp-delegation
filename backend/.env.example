# ── WhatsApp (maytapi) ────────────────────────────────
WA_PRODUCT_ID=your_product_id_here
WA_TOKEN=your_token_here
WA_PHONE_ID=your_phone_id_here
WA_BASE_URL=https://gate.whapi.cloud

# ── OpenAI ────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Sheets ─────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here

# For local dev: path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=./google_service_account.json

# For Render: paste the entire JSON file content as one line
GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT=

# ── Google Drive (optional) ───────────────────────────
GOOGLE_DRIVE_FOLDER_ID=

# ── App ───────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
